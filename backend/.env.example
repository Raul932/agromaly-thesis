# ==============================================================================
# Agromaly — Environment Variables Template
# INSTRUCTIONS: Copy this file to `.env` and fill in your actual values.
# NEVER commit the `.env` file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_ENV=development          # Options: development | staging | production
APP_NAME="Agromaly API"
APP_VERSION="0.1.0"
DEBUG=true                   # Set to false in production

# ------------------------------------------------------------------------------
# Security — JWT
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
# ------------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_to_a_long_random_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# Database — PostgreSQL + PostGIS
# Format: postgresql+asyncpg://user:password@host:port/dbname
# ------------------------------------------------------------------------------
POSTGRES_USER=agromaly
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=agromaly_db
POSTGRES_HOST=db                         # Docker service name
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Sync URL for Alembic (uses psycopg2, not asyncpg)
DATABASE_SYNC_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ------------------------------------------------------------------------------
# Redis — Celery Broker & Result Backend
# ------------------------------------------------------------------------------
REDIS_HOST=redis                         # Docker service name
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1

# ------------------------------------------------------------------------------
# OpenAI — LLM & Embeddings
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------------
# Weather API (e.g., Open-Meteo is free and open; or use OpenWeatherMap)
# ------------------------------------------------------------------------------
WEATHER_API_KEY=CHANGE_ME_or_leave_empty_for_open_meteo
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1

# ------------------------------------------------------------------------------
# ChromaDB — Vector Store (local persistence path)
# ------------------------------------------------------------------------------
CHROMA_PERSIST_DIRECTORY=/app/data/chroma

# ------------------------------------------------------------------------------
# CORS — Allowed Frontend Origins (comma-separated)
# ------------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ------------------------------------------------------------------------------
# Rate Limiting (via slowapi)
# ------------------------------------------------------------------------------
RATE_LIMIT_DEFAULT=100/minute

# ------------------------------------------------------------------------------
# Flower — Celery Monitoring UI
# ------------------------------------------------------------------------------
FLOWER_BASIC_AUTH=admin:CHANGE_ME_flower_password
